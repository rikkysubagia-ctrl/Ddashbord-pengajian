body {
    font-family: Arial;
    background: #f2f5f3;
    padding: 20px;
}

h1 {
    text-align: center;
}

.card {
    background: white;
    padding: 20px;
    margin: 15px;
    border-radius: 10px;
}

button {
    padding: 12px;
    background: green;
    color: white;
    border: none;
    border-radius: 8px;
}
